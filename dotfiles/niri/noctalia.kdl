layout {

    focus-ring {
        active-color   "#ffb1c4"
        inactive-color "#171213"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb1c4"
        inactive-color "#171213"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb1c4"
        inactive-color "#7c2945"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb1c480"
    }
}

recent-windows {
    highlight {
        active-color "#ffb1c4"
        urgent-color "#ffb4ab"
    }
}
